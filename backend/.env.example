# ============================================
# CREAVIX WORLD - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/creavixworld?retryWrites=true&w=majority

# JWT Secret (generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_64_chars
JWT_EXPIRES_IN=7d

# Reset Password Token Secret
RESET_TOKEN_SECRET=your_reset_token_secret_change_this_too

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=teamcreavixworld.org@gmail.com
EMAIL_PASS=your_gmail_app_password_here
EMAIL_FROM=CREAVIX WORLD <teamcreavixworld.org@gmail.com>

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:5173

# Admin credentials (for seeding)
ADMIN_EMAIL=admin@creavixworld.com
ADMIN_PASSWORD=Admin@123

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Cookie
COOKIE_SECRET=your_cookie_secret_here

# File Upload
MAX_FILE_SIZE=5242880
